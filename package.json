{
  "name": "nova-phi-ultra",
  "version": "5.0.0",
  "description": "NOVA-Phi ULTRA Sovereign Encryption Engine",
  "main": "main.js",
  "author": "NOVA Security",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.novasecurity.novaphiultra",
    "productName": "NOVA-Phi-ULTRA",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "shortcutName": "NOVA-Phi ULTRA"
    }
  }
}
